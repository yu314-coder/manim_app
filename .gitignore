# macOS
.DS_Store

# Xcode build artifacts
build/
DerivedData/
*.xcuserstate
xcuserdata/
*.xcworkspace/xcuserdata/

# Reference clones / vendored upstream sources kept locally for grep,
# never pushed (see python-ios-lib + CodeBench upstream repos).
/_vendor/

# Busytex web build (~237 MB; texlive-basic.data is 100 MB which hits
# GitHub's per-file limit). Fetch separately from the busytex release
# and drop the unpacked bundle at ManimStudio/ManimStudio/Resources/Busytex/
# before building.
ManimStudio/ManimStudio/Resources/Busytex/

# Last-archive logs from the SwiftSupport injector script.
scripts/last-archive-postaction.log

# macOS Python pip cache — populated by install-python-macos.sh on first
# build (or scripts/fetch-macos-python.sh + manual pip). 508 MB, not for
# git. Each clone reproduces it via:
#   /usr/local/bin/python3.14 -m pip install --target _vendor/macos-site-packages -r requirements-macos.txt
_vendor/macos-site-packages/

# BeeWare macOS support download cache (the script writes here while
# fetching the macOS Python.xcframework slice).
_vendor/beeware/.macos-python-fetch/

# Backup xcframeworks the fetch script leaves behind on each merge.
_vendor/beeware/Python.xcframework.bak.*
